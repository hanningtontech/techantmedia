# Firebase (client — Vite exposes only VITE_* vars)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=hanningtonkutria-portfolio
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: external NCLEX app URL (marketing link)
VITE_NCLEX_APP_URL=

# Backblaze B2 — server (dev Express on :3002) and Firebase Functions (production /api)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=

# Firebase Admin (local API uploads) — MUST be project hanningtonkutria-portfolio
# 1. Firebase Console → hanningtonkutria-portfolio → Project settings → Service accounts
# 2. Generate new private key → save as service-account.json in this folder
# 3. Uncomment:
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
#
# Or paste fields from that JSON:
# FIREBASE_PROJECT_ID=hanningtonkutria-portfolio
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@hanningtonkutria-portfolio.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Portfolio dev — one port for site + admin uploads (default 5000)
# DEV_WEB_PORT=5000
