rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userDoc().role
        : "student";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isTutorOrAdmin() {
      return isSignedIn() && userRole() in ["tutor", "admin"];
    }

    function userIsSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'hanningtonkuria5@gmail.com'
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userDoc().isSuperAdmin == true)
      );
    }

    function hasAdminScope(scope) {
      return userIsSuperAdmin() || (
        isAdmin()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          !userDoc().keys().hasAny(['adminScopes'])
          || scope in userDoc().adminScopes
        )
      );
    }

    function canManageTutoringContent() {
      return isTutorOrAdmin() && (userRole() == 'tutor' || hasAdminScope('tutoring'));
    }

    function studentNotificationHasPlainNote(r) {
      return r.keys().hasAny(['noteBody'])
        && r.noteBody is string
        && r.noteBody.size() > 0;
    }

    function studentNotificationHasQuestionBlock(r) {
      return r.questionText is string
        && r.questionText.size() > 0
        && r.options is list
        && r.options.size() >= 2
        && r.explanationsText is string
        && r.explanationsText.size() > 0;
    }

    function isClient() {
      return isSignedIn() && userRole() == "client";
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (
          !request.resource.data.keys().hasAny(['role'])
          || request.resource.data.role in ['student', 'client']
        );
      allow update: if userIsSuperAdmin()
        || (
          request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'approvalStatus', 'adminScopes', 'isSuperAdmin'
          ])
        )
        || (
          isAdmin()
          && resource.data.role != 'admin'
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'adminScopes', 'isSuperAdmin', 'role'
          ])
        );
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (userRole() == "tutor" || (isAdmin() && hasAdminScope('tutoring')));
      allow update, delete: if isSignedIn()
        && (resource.data.createdBy == request.auth.uid || userIsSuperAdmin() || (isAdmin() && hasAdminScope('tutoring')));
    }

    /** Distractor / “why others are wrong” copy — tutors may write; only admins may read. */
    match /questions/{questionId}/adminOnly/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSignedIn() && (
        userIsSuperAdmin()
        || (isAdmin() && hasAdminScope('tutoring'))
        || (
          userRole() == "tutor"
          && exists(/databases/$(database)/documents/questions/$(questionId))
          && get(/databases/$(database)/documents/questions/$(questionId)).data.createdBy == request.auth.uid
        )
      );
    }

    match /quizTemplates/{quizId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (userRole() == "tutor" || (isAdmin() && hasAdminScope('tutoring')));
      allow update, delete: if isSignedIn()
        && (resource.data.createdBy == request.auth.uid || userIsSuperAdmin() || (isAdmin() && hasAdminScope('tutoring')));
    }

    match /quizSessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.tutorId == request.auth.uid ||
        resource.data.tutorId == "" ||
        userRole() in ["tutor", "admin"]
      );
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (
        userRole() in ["tutor", "admin"]
        || (
          resource.data.studentId == request.auth.uid
          && resource.data.status == "in_progress"
          && request.resource.data.status == "in_progress"
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.tutorId == resource.data.tutorId
        )
        || (
          resource.data.studentId == request.auth.uid
          && resource.data.status == "in_progress"
          && request.resource.data.status == "submitted"
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.tutorId == resource.data.tutorId
          && request.resource.data.resultsReleasedToStudent == false
        )
      );
      allow delete: if isSignedIn() && userRole() in ["tutor", "admin"];
    }

    match /quizAssignments/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || userRole() in ["tutor", "admin"]
      );
      allow create, update, delete: if isSignedIn() && userRole() in ["tutor", "admin"];
    }

    match /ratSessions/{ratId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.studentId == request.auth.uid
        && request.resource.data.studentId == resource.data.studentId;
      allow delete: if isSignedIn() && isAdmin();
    }

    match /adminNotifications/{notificationId} {
      allow read: if isAdmin() && (userIsSuperAdmin() || hasAdminScope('tutoring'));
      allow create, delete: if false;
      allow update: if isAdmin() && (userIsSuperAdmin() || hasAdminScope('tutoring'))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read", "readAt"]);
    }

    /** Admin → student teaching notes: plain note and/or question + choices + explanations. */
    match /studentNotifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || isAdmin()
      );

      allow create: if isAdmin() && (userIsSuperAdmin() || hasAdminScope('tutoring'))
        && request.resource.data.keys().hasAll([
          "studentId", "createdBy", "read", "title", "questionText", "options", "explanationsText"
        ])
        && request.resource.data.studentId is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.read == false
        && request.resource.data.questionText is string
        && request.resource.data.explanationsText is string
        && request.resource.data.title is string
        && request.resource.data.options is list
        && (
          studentNotificationHasPlainNote(request.resource.data)
          || studentNotificationHasQuestionBlock(request.resource.data)
        );

      allow update: if (isAdmin() && (userIsSuperAdmin() || hasAdminScope('tutoring')))
        || (
          resource.data.studentId == request.auth.uid
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read", "readAt"])
        );

      allow delete: if isAdmin() && (userIsSuperAdmin() || hasAdminScope('tutoring'));
    }

    /** Admin-uploaded class PPTX presentations (shown to students under Notes → Presentations). */
    match /classPresentations/{presentationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.published == true);
      allow create, update, delete: if canManageTutoringContent();
    }

    /** Admin-uploaded study guides (PDF/DOC/DOCX). */
    match /classStudyGuides/{docId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.published == true);
      allow create, update, delete: if canManageTutoringContent();
    }

    /** Tutor/admin-authored study notes (text); tagged by NCLEX track and catalog hierarchy. */
    match /classNotes/{noteId} {
      allow read: if isSignedIn() && (canManageTutoringContent() || resource.data.published == true);
      allow create, update, delete: if canManageTutoringContent();
    }

    /** Instructor-led tutoring sessions: quiz bundles + roster; students read only when published and assigned. */
    match /tutoringSessions/{sessionId} {
      allow read: if isSignedIn() && (
        canManageTutoringContent()
        || (
          resource.data.published == true
          && request.auth.uid in resource.data.assignedStudentIds
        )
      );
      allow create: if canManageTutoringContent()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canManageTutoringContent() && (
        userIsSuperAdmin()
        || !resource.data.keys().hasAny(['locked'])
        || resource.data.locked != true
      );
    }

    /** Per-student session row: extra quizzes, exclusions, tutor notes. */
    match /tutoringSessions/{sessionId}/participants/{studentId} {
      allow read: if isSignedIn() && (
        canManageTutoringContent()
        || (
          get(/databases/$(database)/documents/tutoringSessions/$(sessionId)).data.published == true
          && request.auth.uid == studentId
          && studentId in get(/databases/$(database)/documents/tutoringSessions/$(sessionId)).data.assignedStudentIds
        )
      );
      allow create, update, delete: if canManageTutoringContent() && (
        userIsSuperAdmin()
        || !get(/databases/$(database)/documents/tutoringSessions/$(sessionId)).data.keys().hasAny(['locked'])
        || get(/databases/$(database)/documents/tutoringSessions/$(sessionId)).data.locked != true
      );
    }

    /** Student asks admin to unlock a locked session (doc id = studentId). */
    /** Public portfolio storefront content (home page). Anyone can read; scoped admins can edit. */
    /** Storefront CMS — public read; writes only via Admin SDK (API). */
    match /portfolio/{docId} {
      allow read: if true;
      allow write: if false;
    }

    /** RTMP stream keys — API (Admin SDK) only. */
    match /adminSecrets/{docId} {
      allow read, write: if false;
    }

    /** Photography client private galleries — owner read; admin writes via API. */
    match /clientGalleries/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if false;

      match /photos/{photoId} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow write: if false;
      }
    }

    /** Signed contracts — read by admin or owning client; writes via API only. */
    match /signedContractSubmissions/{submissionId} {
      allow read: if isAdmin() && (userIsSuperAdmin() || hasAdminScope('photography'))
        || (isClient() && resource.data.clientId == request.auth.uid);
      allow write: if false;
    }

    /** Client inspiration boards — public read; create/delete via API only. */
    match /inspoBoards/{boardId} {
      allow read: if true;
      allow write: if false;
    }

    /** NTSA data extraction — saved and cleared session archives per user. */
    match /ntsaExtractionRecords/{recordId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || userIsSuperAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ['saved', 'cleared']
        && request.resource.data.rows is list;
      allow update: if userIsSuperAdmin()
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'restoreRequested', 'restoreRequestedAt', 'updatedAt'
          ])
        );
      allow delete: if userIsSuperAdmin();
    }

    /** Pending restored sessions pushed to a user by admin. */
    match /ntsaExtractions/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || userIsSuperAdmin());
      allow create, update: if userIsSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      allow delete: if userIsSuperAdmin();
    }

    match /tutoringSessions/{sessionId}/unlockRequests/{reqStudentId} {
      function tutoringSessionData() {
        return get(/databases/$(database)/documents/tutoringSessions/$(sessionId)).data;
      }
      allow read: if isSignedIn() && (
        canManageTutoringContent()
        || (
          request.auth.uid == reqStudentId
          && exists(/databases/$(database)/documents/tutoringSessions/$(sessionId))
          && tutoringSessionData().published == true
          && reqStudentId in tutoringSessionData().assignedStudentIds
        )
      );
      allow create, update: if isSignedIn()
        && request.auth.uid == reqStudentId
        && reqStudentId == request.resource.data.studentId
        && exists(/databases/$(database)/documents/tutoringSessions/$(sessionId))
        && tutoringSessionData().published == true
        && reqStudentId in tutoringSessionData().assignedStudentIds
        && tutoringSessionData().keys().hasAny(['locked'])
        && tutoringSessionData().locked == true
        && request.resource.data.status == 'pending'
        && request.resource.data.message is string
        && request.resource.data.message.size() < 2000;
      allow delete: if canManageTutoringContent();
    }

    /** API quota counters — Cloud Functions (Admin SDK) only. */
    match /system/apiQuota/{dayId} {
      allow read, write: if false;
    }

    /** Block game — public live chart; authenticated wallets & fund requests. */
    match /blockGame/liveChart {
      allow read: if true;
      allow write: if isSignedIn();

      match /pages/{pageId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /blockGame/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blockGameWallets/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /blockGameFundRequests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if isAdmin();
    }

    match /blockGameSimPins/{pinId} {
      allow read, write: if false;
    }

    match /blockGamePlayerRounds/{roundId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.playedAtMs is number
        && request.resource.data.adminRevenue is number
        && request.resource.data.userProfit is number
        && request.resource.data.userStake is number;
      allow update, delete: if false;
    }

    match /blockGamePlayers/{playerId} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == playerId;
      allow delete: if false;
    }

    match /blockGame/playerRevenue {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }
  }
}
